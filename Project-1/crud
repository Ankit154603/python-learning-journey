def deletefile():
    try:
        readfileandfolder()
        name = input("which file you want to delete: ")
        p = Path(name)

        if p.exists() and p.is_file():
            os.remove(p)

            print("File Removed successfully")

        else:
            print("No such file exists")

    except Exception as err:
        print(f"An error occured as {err}")

